{
  "comment": "check:lang allowlist — platform-fixed API names and namespaces that legitimately contain American spellings (spec §13.6). Each pattern is a case-insensitive regular expression; matched substrings are removed from a line before the American-spelling scan runs.",
  "patterns": [
    {
      "pattern": "--color-[a-z0-9-]+",
      "reason": "Tailwind 4 @theme colour-token namespace is platform-fixed"
    },
    {
      "pattern": "\\b(?:text|bg|border|outline|ring|fill|stroke|accent|caret|decoration|divide|shadow|from|via|to)-(?:bb|current|transparent|inherit|white|black)[a-z0-9-]*",
      "reason": "Tailwind colour-utility class prefixes"
    },
    {
      "pattern": "\\b(?:items|justify|content|place-items|place-content|place-self|self|text|origin|object)-center\\b",
      "reason": "Tailwind layout utilities use the CSS 'center' keyword"
    },
    {
      "pattern": ":\\s*center\\b",
      "reason": "CSS property value 'center' is platform-fixed"
    },
    {
      "pattern": "\\b(?:background-color|border-color|outline-color|accent-color|caret-color|scrollbar-color|text-decoration-color|-webkit-[a-z-]+)\\b",
      "reason": "CSS property names are platform-fixed"
    },
    {
      "pattern": "(?<![a-z-])color\\s*:",
      "reason": "CSS 'color:' property is platform-fixed"
    },
    {
      "pattern": "\\bcolor-scheme\\b",
      "reason": "CSS 'color-scheme' property is platform-fixed"
    },
    {
      "pattern": "\\bprefers-color-scheme\\b",
      "reason": "CSS media feature is platform-fixed"
    },
    {
      "pattern": "\\btheme[-_]color\\b",
      "reason": "Web-manifest/meta key is platform-fixed"
    },
    {
      "pattern": "\\bbackground_color\\b",
      "reason": "Web-manifest key is platform-fixed"
    },
    {
      "pattern": "\\bcurrentColor\\b",
      "reason": "CSS keyword is platform-fixed"
    },
    {
      "pattern": "\\.normalize\\b",
      "reason": "String.prototype.normalize and ConvolverNode.normalize are platform-fixed"
    },
    {
      "pattern": "\\bnormalize\\b(?=\\s*[:=])",
      "reason": "ConvolverNode.normalize property field (platform-fixed API name)"
    },
    {
      "pattern": "\\btransition-colors\\b",
      "reason": "Tailwind transition utility is platform-fixed"
    },
    {
      "pattern": "getModifierState|AnalyserNode",
      "reason": "Platform API names (spec §13.6 examples)"
    },
    {
      "pattern": "\\boptimizeDeps\\b",
      "reason": "Vite configuration API name is platform-fixed"
    },
    {
      "pattern": "\\bstop-color\\b",
      "reason": "SVG gradient attribute name is platform-fixed"
    }
  ]
}
